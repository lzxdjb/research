# Three separate trainable models for digital onboarding.
#
# It is okay to initialize all three from the same pretrained base checkpoint,
# but each training job writes to a different checkpoint directory and becomes a
# different model after training.

# S_pi: service / problem-solving / tool-use policy.
SERVICE_MODEL_PATH=/mnt/data/HithinkOmniSSD/user_workspace/leizhengxing/verl/data/Qwen3-4B

# C_theta: customer simulator policy.
SIM_MODEL_PATH=/mnt/data/HithinkOmniSSD/user_workspace/leizhengxing/verl/data/Qwen3-4B

# R_phi: small learned reward model.
RM_MODEL_PATH=/mnt/data/HithinkOmniSSD/user_workspace/leizhengxing/verl/data/Qwen3-4B

# T: large fixed teacher. This is not the same thing as R_phi.
TEACHER_ENDPOINT=http://127.0.0.1:8002/v1/chat/completions
TEACHER_MODEL=/path/to/your/122B-A10B

# Runtime endpoints used by service-model rollouts.
# During early quick tests, these can point to the 122B teacher.
# In real closed-loop training, point them to the latest trained C_theta/R_phi.
CUSTOMER_ENDPOINT=http://127.0.0.1:8000/v1/chat/completions
CUSTOMER_MODEL=/path/to/latest-C-theta-checkpoint

REWARD_ENDPOINT=http://127.0.0.1:8001/v1/chat/completions
REWARD_MODEL=/path/to/latest-R-phi-checkpoint
